---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, category } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>

    <nav>
      <div class="nav-logo"><a href="/">Witholi</a></div>
      <ul class="nav-links">
        <li><a href="/blog">Articles</a></li>
        <li><a href="#">Topics</a></li>
        <li><a href="#">About</a></li>
        <li><a href="#">Newsletter</a></li>
      </ul>
    </nav>

    <main>
      <div class="post-header">
        <div class="hero-tag">{category ?? 'Health'}</div>
        <h1>{title}</h1>
        <p class="description">{description}</p>
        <div class="post-meta">
          <FormattedDate date={pubDate} />
        </div>
      </div>

      <article class="prose">
        <slot />
      </article>

      <div class="back-link">
        <a href="/blog">← Back to all articles</a>
      </div>
    </main>

    <footer>
      <p>© 2026 Witholi · Written with care</p>
    </footer>

  </body>
</html>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #FBF7F2;
    color: #2C2018;
    min-height: 100vh;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 3rem;
    border-bottom: 1px solid #EDE5D8;
  }

  .nav-logo a {
    font-family: 'Lora', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: #7C4A2D;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.9rem;
    color: #6B5040;
    text-decoration: none;
  }

  .nav-links a:hover { color: #7C4A2D; }

  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .post-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #EDE5D8;
  }

  .hero-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #A0673A;
    background: #F5E6D3;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    margin-bottom: 1.25rem;
  }

  .post-header h1 {
    font-family: 'Lora', serif;
    font-size: 2.5rem;
    font-weight: 600;
    line-height: 1.25;
    color: #2C2018;
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1rem;
    line-height: 1.75;
    color: #6B5040;
    font-weight: 300;
    margin-bottom: 1rem;
  }

  .post-meta {
    font-size: 0.8rem;
    color: #9E7A5E;
  }

  .prose {
    font-size: 1rem;
    line-height: 1.85;
    color: #2C2018;
    font-weight: 300;
  }

  .prose h2 {
    font-family: 'Lora', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #2C2018;
    margin: 2.5rem 0 1rem;
  }

  .prose h3 {
    font-family: 'Lora', serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: #2C2018;
    margin: 2rem 0 0.75rem;
  }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose a {
    color: #A0673A;
    text-decoration: underline;
  }

  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose strong {
    font-weight: 500;
    color: #2C2018;
  }

  .back-link {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #EDE5D8;
  }

